# 사주공학 환경 설정 파일
# 이 파일을 .env로 복사하고 실제 값으로 변경하세요

# =============================================================================
# API 서비스 설정
# =============================================================================

# Anthropic Claude API 키 (필수)
# Claude AI를 사용한 사주 해석을 위해 필요합니다
# https://console.anthropic.com에서 발급받을 수 있습니다
ANTHROPIC_API_KEY=__set_in_local_env__

# API 서버 포트 (기본값: 8000)
API_PORT=8000

# API 서버 호스트 (기본값: 0.0.0.0)
API_HOST=0.0.0.0

# =============================================================================
# 데이터베이스 설정
# =============================================================================

# PostgreSQL 데이터베이스 URL (필수)
# 형식: postgresql://username:password@host:port/database
# Docker Compose 사용 시 기본값
DATABASE_URL=postgresql://saju:saju@localhost:5432/saju

# 데이터베이스 연결 풀 설정
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# =============================================================================
# Redis 설정 (작업 큐용)
# =============================================================================

# Redis 서버 URL (필수)
# BullMQ 작업 큐와 캐싱을 위해 사용됩니다
REDIS_URL=redis://localhost:6379

# Redis 연결 설정
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3

# =============================================================================
# YouTube API 설정
# =============================================================================

# YouTube Data API v3 키 (필수)
# 비디오 업로드와 메타데이터 관리를 위해 필요합니다
# Google Cloud Console에서 발급받을 수 있습니다
YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube OAuth 클라이언트 정보 (필수)
# YouTube에 비디오를 업로드하기 위해 필요합니다
YOUTUBE_CLIENT_SECRET_PATH=./secrets/client_secret.json
YOUTUBE_TOKEN_PATH=./secrets/token.json

# YouTube 채널 설정
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxx
YOUTUBE_UPLOAD_PRIVACY=private # public, unlisted, private

# =============================================================================
# Next.js 웹 앱 설정
# =============================================================================

# Next.js 앱 URL (기본값: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# NextAuth.js 암호화 키 (필수)
# 32자 이상의 랜덤 문자열을 사용하세요
# openssl rand -base64 32 명령으로 생성할 수 있습니다
NEXTAUTH_SECRET=your-secret-key-here-make-it-very-long-and-random

# 웹 앱 포트 (기본값: 3000)
WEB_PORT=3000

# =============================================================================
# 보안 설정
# =============================================================================

# JWT 서명 키 (필수)
# API 인증을 위한 JWT 토큰 서명에 사용됩니다
JWT_SECRET=your-jwt-secret-key-here-make-it-very-secure

# CORS 설정
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# API 요청 제한
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60 # 초

# =============================================================================
# 파일 저장소 설정
# =============================================================================

# 로컬 스토리지 경로
OUTPUT_DIR=./storage
STORAGE_PATH=/app/storage

# 임시 파일 경로
TEMP_PATH=/tmp/saju-engine

# 최대 업로드 크기 (MB)
MAX_UPLOAD_SIZE=100

# =============================================================================
# 비디오 렌더링 설정
# =============================================================================

# Remotion 렌더링 설정
REMOTION_BROWSER_EXECUTABLE=/usr/bin/chromium-browser
REMOTION_CONCURRENCY=2
REMOTION_TIMEOUT_SECONDS=300

# FFmpeg 설정
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_QUALITY=720p # 1080p, 720p, 480p
VIDEO_FPS=30

# =============================================================================
# TTS (텍스트 음성 변환) 설정
# =============================================================================

# Edge TTS 음성 설정
TTS_VOICE=ko-KR-SunHiNeural # 한국어 여성 음성
TTS_RATE=medium # slow, medium, fast
TTS_VOLUME=100 # 0-100

# Azure Speech Service (선택사항)
# Edge TTS 대신 Azure Speech를 사용하려면 설정
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# =============================================================================
# 사주 계산 설정
# =============================================================================

# 사주 계산 설정
SAJU_TIMEZONE=Asia/Seoul
SAJU_TRUE_SOLAR_TIME=true
SAJU_ZISHI_POLICY=late_early   # 야자시/조자시 분단

# =============================================================================
# 모니터링 및 로깅
# =============================================================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE=/var/log/saju-engine/app.log

# 메트릭 수집 설정
ENABLE_METRICS=true
METRICS_PORT=8001

# Sentry 오류 추적 (선택사항)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# 개발 환경 설정
# =============================================================================

# 환경 모드 (development, production, test)
NODE_ENV=development

# 디버그 모드
DEBUG=true

# Hot reload 설정
FAST_REFRESH=true

# 개발용 목 API 사용 여부
USE_MOCK_APIS=false

# =============================================================================
# 비용 관리 설정
# =============================================================================

# Claude API 사용량 제한 (월 USD)
ANTHROPIC_BUDGET_LIMIT=100.00

# YouTube API 할당량 관리
YOUTUBE_QUOTA_LIMIT=10000

# 비용 알림 이메일
COST_ALERT_EMAIL=admin@example.com

# =============================================================================
# 커리큘럼 설정
# =============================================================================

# 커리큘럼 파일 경로
CURRICULUM_PATH=/app/curriculum/30day.yaml

# 에피소드 자동 생성 설정
AUTO_GENERATE_EPISODES=true
EPISODES_PER_DAY=1

# =============================================================================
# 기타 설정
# =============================================================================

# 시간대 설정
TIMEZONE=Asia/Seoul

# 애플리케이션 버전
APP_VERSION=1.0.0

# 애플리케이션 이름
APP_NAME="사주공학"

# 기본 언어
DEFAULT_LOCALE=ko-KR

# =============================================================================
# Docker 설정 (docker-compose.yml에서 사용)
# =============================================================================

# PostgreSQL Docker 설정
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=saju_engine

# Redis Docker 설정
REDIS_PASSWORD_DOCKER=

# 포트 매핑
POSTGRES_PORT=5432
REDIS_PORT=6379

# =============================================================================
# 사용 예시
# =============================================================================

# 1. 이 파일을 .env로 복사:
#    cp .env.example .env

# 2. 필수 값들을 설정:
#    - ANTHROPIC_API_KEY: Claude API 키
#    - DATABASE_URL: PostgreSQL 연결 정보
#    - REDIS_URL: Redis 연결 정보
#    - NEXTAUTH_SECRET: 랜덤 암호화 키
#    - JWT_SECRET: JWT 서명 키

# 3. 선택적 설정:
#    - YOUTUBE_* 설정들 (YouTube 업로드 기능 사용 시)
#    - AZURE_SPEECH_* 설정들 (Azure TTS 사용 시)
#    - SENTRY_DSN (오류 추적 사용 시)

# 4. 개발 환경에서는 USE_MOCK_APIS=true로 설정하여
#    외부 API 없이 테스트할 수 있습니다.